---
import LinkArrow from './LinkArrow.astro';

interface Props {
	title: string;
	description: string;
	href?: string;
	color?: 'cyan' | 'yellow' | 'magenta' | 'green' | 'navy' | 'buytrade';
}

const { title, description, href = '#', color = 'cyan' } = Astro.props;

const colorMap = {
	cyan: 'var(--color-tradehelp-cyan)',
	yellow: 'var(--color-tradehelp-yellow)',
	magenta: 'var(--color-tradehelp-magenta)',
	green: 'var(--color-tradehelp-green)',
	navy: 'var(--color-tradehelp-navy)',
	buytrade: 'var(--color-tradehelp-buytrade)',
};

const hex = colorMap[color];
---

<a
	href={href}
	class='card px-5 py-8 flex flex-col gap-2 group transition-all duration-300 hover:shadow-lg hover:-translate-y-1 h-full'>
	<div
		class='inline-flex rounded-xl p-2 items-center justify-center text-white self-start mb-2'
		style={`background-color: ${hex}`}>
		<slot />
	</div>

	<h5 class='text-text-primary'>{title}</h5>

	<p class='text-text-secondary text-sm'>{description}</p>

	<LinkArrow text='Learn More' ariaLabel={`Learn more about ${title}`} color={color} class='mt-auto pt-2' />
</a>
