---
interface Props {
	title: string;
	description: string;
	url: string;
	date?: string;
}

const { title, description, url, date } = Astro.props;
---

<a
	href={url}
	class='block group border border-secondary-100 p-4 bg-white rounded-lg transition-all duration-300 hover:border-primary-400 hover:shadow-sm hover:-translate-y-0.5 no-underline'>
	{date && <span class='text-xs text-secondary-400 uppercase tracking-wider'>{date}</span>}

	<h3 class='text-text-primary text-[1rem] font-semibold transition-colors mb-0'>
		{title}
	</h3>

	<p class='text-text-primary/60 font-medium text-sm mb-1 truncate overflow-hidden whitespace-nowrap'>
		{description}
	</p>
</a>
