---
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/home/HeroSection.astro';
import FeatureCardsSection from '../components/home/FeatureCardsSection.astro';
import ProductsSection from '../components/home/ProductsSection.astro';
import TrustPilotHighlight from '../components/TrustPilotHighlight.astro';
import JoinTheNetworkBanner from '../components/JoinTheNetworkBanner.astro';
import WhoAreTradeHelpSection from '../components/home/WhoAreTradeHelpSection.astro';
import PartnersSection from '../components/home/PartnersSection.astro';
import LatestNewsSection from '../components/home/LatestNewsSection.astro';
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<HeroSection />
	<FeatureCardsSection />
	<TrustPilotHighlight />
	<ProductsSection />
	<JoinTheNetworkBanner />
	<WhoAreTradeHelpSection />
	<PartnersSection />
	<LatestNewsSection />
</Layout>
